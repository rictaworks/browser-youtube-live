RAILS_MASTER_KEY=your_master_key_here

DATABASE_URL=postgresql://user:password@localhost/browser_youtube_live_production

FRONTEND_ORIGIN=http://localhost:3000

# bin/rails db:encryption:init で生成した値を設定すること
AR_ENCRYPTION_PRIMARY_KEY=<bin/rails db:encryption:init で生成>
AR_ENCRYPTION_DETERMINISTIC_KEY=<bin/rails db:encryption:init で生成>
AR_ENCRYPTION_KEY_DERIVATION_SALT=<bin/rails db:encryption:init で生成>

# Google Cloud Console で取得した OAuth 2.0 クライアント認証情報
GOOGLE_CLIENT_ID=<Google Cloud Console で取得>
GOOGLE_CLIENT_SECRET=<Google Cloud Console で取得>

# bin/rails secret で生成した値を設定すること
DEVISE_JWT_SECRET_KEY=<bin/rails secret で生成>
